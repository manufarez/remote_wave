#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "dotenv/load"
require "thor"

require_relative "../lib/remote_client"
require_relative "../lib/wave_client"
require_relative "../lib/syncer"
require_relative "../lib/revolut_statement"
require_relative "../lib/reconciler"

class CLI < Thor
  default_command :run_sync

  desc "setup", "Find your Wave business ID and account IDs"
  def setup
    token = ENV["WAVE_ACCESS_TOKEN"]
    if token.nil? || token.empty?
      puts "Set WAVE_ACCESS_TOKEN in .env first (Full Access Token from developer.waveapps.com)"
      exit 1
    end

    wave = WaveClient.new(access_token: token)

    puts "=== Your Wave Businesses ==="
    businesses = wave.list_businesses
    businesses.each do |biz|
      puts "  #{biz["name"]} → WAVE_BUSINESS_ID=#{biz["id"]}  (#{biz.dig("currency", "code")})"
    end

    biz_id = ENV["WAVE_BUSINESS_ID"]
    if biz_id && !biz_id.empty?
      wave_with_biz = WaveClient.new(access_token: token, business_id: biz_id)
      biz_name = businesses.find { |b| b["id"] == biz_id }&.dig("name") || biz_id

      puts "\n=== Products / Services for #{biz_name} ==="
      products = wave_with_biz.list_products
      if products.any?
        products.each do |p|
          puts "  #{p["name"]} → WAVE_PRODUCT_ID=#{p["id"]}  (#{p["unitPrice"]})"
        end
      else
        puts "  No products found. Create one in Wave first (e.g. 'Contractor Services')."
      end

      puts "\nSet WAVE_PRODUCT_ID in .env."
    else
      puts "\nSet WAVE_BUSINESS_ID in .env, then run setup again to see accounts."
    end
  end

  desc "debug_accounts", "List receivable invoice accounts (for debugging)"
  def debug_accounts
    token = ENV.fetch("WAVE_ACCESS_TOKEN")
    biz_id = ENV.fetch("WAVE_BUSINESS_ID")
    wave = WaveClient.new(access_token: token, business_id: biz_id)

    accounts = wave.list_accounts
    receivables = accounts.select { |a| a.dig("subtype", "value")&.include?("RECEIVABLE") }

    if receivables.any?
      puts "=== Receivable Accounts ==="
      receivables.each do |acc|
        puts "  #{acc["name"]} | type=#{acc.dig("type", "value")} subtype=#{acc.dig("subtype", "value")} | id=#{acc["id"]}"
      end
    else
      puts "No receivable accounts found."
      puts "\nAll account subtypes:"
      accounts.map { |a| a.dig("subtype", "value") }.uniq.compact.sort.each { |s| puts "  #{s}" }
    end
  end

  desc "run_sync", "Sync paid invoices from Remote.com CSV export to Wave"
  option :csv, type: :string, required: true, desc: "Path to Remote.com contractor invoices CSV export"
  option :since, type: :string, desc: "Only sync invoices after this date (YYYY-MM-DD)"
  option :dry_run, type: :boolean, default: false, desc: "Preview changes without creating anything"

  def run_sync
    validate_env!
    validate_csv!

    remote = RemoteClient.new(csv_path: options[:csv])

    wave = WaveClient.new(
      access_token: ENV.fetch("WAVE_ACCESS_TOKEN"),
      business_id: ENV.fetch("WAVE_BUSINESS_ID"),
      anchor_account_id: ENV.fetch("WAVE_ANCHOR_ACCOUNT_ID")
    )

    product_id = ENV.fetch("WAVE_PRODUCT_ID")
    syncer = Syncer.new(remote_client: remote, wave_client: wave, dry_run: options[:dry_run], product_id: product_id)

    puts options[:dry_run] ? "=== DRY RUN MODE ===" : "=== Syncing invoices ==="
    puts "CSV: #{options[:csv]}"
    puts "Since: #{options[:since]}" if options[:since]
    puts

    syncer.sync(since: options[:since])
  end

  desc "reconcile", "Compare Remote.com CSV paid_out rows against a Revolut Business statement CSV"
  option :csv, type: :string, required: true, desc: "Path to Remote.com contractor invoices CSV"
  option :revolut_csv, type: :string, required: true, desc: "Path to Revolut Business statement CSV"
  option :since, type: :string, desc: "Only include rows on or after this date (YYYY-MM-DD)"

  def reconcile
    validate_file!(options[:csv], "CSV")
    validate_file!(options[:revolut_csv], "Revolut statement CSV")

    csv_rows = RemoteClient.new(csv_path: options[:csv]).paid_invoices(since: options[:since])
    topups = RevolutStatement.new(csv_path: options[:revolut_csv]).remote_topups(since: options[:since])
    result = Reconciler.new(csv_rows: csv_rows, revolut_topups: topups).reconcile

    print_reconciliation_report(
      csv_path: options[:csv],
      statement_path: options[:revolut_csv],
      since: options[:since],
      csv_rows: csv_rows,
      topups: topups,
      result: result
    )
  end

  private

  def validate_file!(path, label)
    return if File.exist?(path)
    puts "#{label} not found: #{path}"
    exit 1
  end

  def print_reconciliation_report(csv_path:, statement_path:, since:, csv_rows:, topups:, result:)
    puts "=== Reconciliation (CSV <-> Revolut statement) ==="
    puts "CSV file:     #{csv_path}"
    puts "Statement:    #{statement_path}"
    puts "Since:        #{since}" if since
    puts "CSV paid_out: #{csv_rows.length}"
    puts "Remote TOPUPs in statement: #{topups.length}"
    puts

    result.warnings.each { |w| puts "[WARN] #{w}" }
    puts unless result.warnings.empty?

    print_bucket("[OK]      Matched", result.matched) do |entry|
      "  #{entry[:csv_row][:invoice_number]}  #{entry[:csv_row][:invoice_date]}  EUR #{format("%.2f", entry[:csv_row][:amount])}"
    end

    print_bucket("[WARN]    Amount mismatch", result.amount_mismatch) do |entry|
      csv = entry[:csv_row]
      tx = entry[:revolut_topup]
      "  ##{csv[:invoice_number]}  CSV: #{format("%.2f", csv[:amount])} #{csv[:currency]}  Revolut: #{format("%.2f", tx[:amount])} #{tx[:currency]}"
    end

    print_bucket("[PENDING] Money not landed yet", result.pending) do |entry|
      csv = entry[:csv_row]
      "  ##{csv[:invoice_number]}  #{csv[:invoice_date]}  expected EUR #{format("%.2f", csv[:amount])}  (#{entry[:age_in_days]} days old)"
    end

    print_bucket("[MISSING] Should have landed", result.missing) do |entry|
      csv = entry[:csv_row]
      "  ##{csv[:invoice_number]}  #{csv[:invoice_date]}  expected EUR #{format("%.2f", csv[:amount])}  (#{entry[:age_in_days]} days old)"
    end

    print_bucket("[?]       Unaccounted Revolut deposits", result.unaccounted) do |entry|
      tx = entry[:revolut_topup]
      "  Ref #{tx[:reference].inspect}  #{tx[:completed_at]}  EUR #{format("%.2f", tx[:amount])}"
    end

    puts "\nSummary: #{result.matched.length} matched, " \
         "#{result.amount_mismatch.length} mismatches, " \
         "#{result.pending.length} pending, " \
         "#{result.missing.length} missing, " \
         "#{result.unaccounted.length} unaccounted"
  end

  def print_bucket(label, entries)
    puts "#{label} (#{entries.length})"
    entries.first(20).each { |e| puts yield(e) }
    puts "  (... #{entries.length - 20} more)" if entries.length > 20
    puts
  end

  def validate_env!
    required = %w[WAVE_ACCESS_TOKEN WAVE_BUSINESS_ID WAVE_ANCHOR_ACCOUNT_ID WAVE_PRODUCT_ID]
    missing = required.select { |key| ENV[key].nil? || ENV[key].empty? }

    return if missing.empty?

    puts "Missing required environment variables:"
    missing.each { |key| puts "  - #{key}" }
    puts "\nCopy .env.example to .env and fill in your credentials."
    exit 1
  end

  def validate_csv!
    return if File.exist?(options[:csv])

    puts "CSV file not found: #{options[:csv]}"
    exit 1
  end
end

CLI.start(ARGV)
